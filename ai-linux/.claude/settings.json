{
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(pwd *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(cd *)",
      "Bash(date *)",
      "Bash(whoami *)",
      "Bash(hostname *)",
      "Bash(uname *)",
      "Bash(id *)",
      "Bash(bash -n *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr diff *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow view *)",
      "Bash(gh search *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git add *)",
      "Bash(git fetch *)",
      "Read(./.env.example)",
      "Read(./.env.sample)",
      "Read(./.git/config)",
      "Read(./Cargo.toml)",
      "Read(./Gemfile)",
      "Read(./Makefile)",
      "Read(./composer.json)",
      "Read(./go.mod)",
      "Read(./package.json)",
      "Read(./requirements.txt)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "mcp__sequential-thinking__sequentialthinking"
    ],
    "deny": [
      "Bash(sudo *)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/.git/credentials)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Read(./.env)",
      "Read(./.envrc)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.ssh/id_*)"
    ],
    "ask": [
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(kill *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(touch *)",
      "Bash(wget *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/SessionStart-startup.sh"
          }
        ]
      },
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/SessionStart-resumed.sh"
          }
        ]
      }
    ],
    "Setup": [
      {
        "matcher": "init|maintenance",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/Setup.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/UserPromptSubmit.sh"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/UserPromptExpansion.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PreToolUse-Bash.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PreToolUse-WebFetch.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PreToolUse-WebSearch.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PermissionRequest.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PermissionDenied-Bash.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PermissionDenied-WebFetch.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PermissionDenied-WebSearch.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUse-Bash.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUse-WebFetch.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUse-WebSearch.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUseFailure-Bash.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUseFailure-WebFetch.sh"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolUseFailure-WebSearch.sh"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/PostToolBatch.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/Notification.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
